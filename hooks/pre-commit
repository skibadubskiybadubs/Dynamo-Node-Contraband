#!/bin/bash
# Pre-commit hook: runs unit tests when tools/ or Revit/ code changes.
#
# Install:  cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or:       python hooks/install_hooks.py

set -e

# Check if any staged files match the patterns we care about
TOOLS_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^tools/.*\.py$' || true)
REVIT_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^Revit/DynamoCliAddIn/.*\.cs$' || true)
TEST_CHANGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^tests/.*\.py$' || true)

if [ -z "$TOOLS_CHANGED" ] && [ -z "$REVIT_CHANGED" ] && [ -z "$TEST_CHANGED" ]; then
    # No relevant files changed, skip tests
    exit 0
fi

echo "Running unit tests (relevant code changed)..."

# Run pytest on unit test files only (exclude IPC E2E tests that need Revit)
python -m pytest tests/test_graph_read.py tests/test_node_create.py tests/test_node_connect.py tests/test_code_inject.py tests/test_execute.py tests/test_output_read.py tests/test_node_delete.py tests/test_node_edit.py -q

if [ $? -ne 0 ]; then
    echo ""
    echo "Unit tests failed. Commit aborted."
    echo "Fix the failing tests or use --no-verify to skip."
    exit 1
fi

echo "All unit tests passed."

# If C# files changed, verify the project builds
if [ -n "$REVIT_CHANGED" ]; then
    echo "C# files changed - verifying build..."
    dotnet build Revit/DynamoCliAddIn/DynamoCliAddIn.csproj -c Debug --nologo -v q 2>&1 | tail -3
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo ""
        echo "C# build failed. Commit aborted."
        exit 1
    fi
    echo "C# build passed."
fi
