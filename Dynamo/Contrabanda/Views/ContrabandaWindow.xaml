<Window x:Class="Contrabanda.ContrabandaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Contrabanda"
        Width="820" Height="580"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#FF2D2D30"
        Foreground="#FFEBEBEB"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>

        <!-- Colours -->
        <SolidColorBrush x:Key="BgPanel"       Color="#FF252526"/>
        <SolidColorBrush x:Key="BgInput"       Color="#FF3C3C3E"/>
        <SolidColorBrush x:Key="BgSend"        Color="#FF0E70B0"/>
        <SolidColorBrush x:Key="BgSendHover"   Color="#FF1182CC"/>
        <SolidColorBrush x:Key="BgUserBubble"  Color="#FF0E70B0"/>
        <SolidColorBrush x:Key="BgBotBubble"   Color="#FF3A3A3C"/>
        <SolidColorBrush x:Key="FgMuted"       Color="#FF9D9D9D"/>
        <SolidColorBrush x:Key="Separator"     Color="#FF3F3F46"/>
        <SolidColorBrush x:Key="FgAccent"      Color="#FF4FC3F7"/>

        <!-- Send button style -->
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource BgSend}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="18,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgSendHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="Background"        Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"        Value="#FFEBEBEB"/>
            <Setter Property="CaretBrush"        Value="#FFEBEBEB"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="BorderBrush"       Value="{StaticResource Separator}"/>
            <Setter Property="Padding"           Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header: graph + project info -->
            <RowDefinition Height="Auto"/>
            <!-- Separator -->
            <RowDefinition Height="1"/>
            <!-- Chat area -->
            <RowDefinition Height="*"/>
            <!-- Input row -->
            <RowDefinition Height="Auto"/>
            <!-- Separator -->
            <RowDefinition Height="1"/>
            <!-- Footer: node selection -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             ROW 0 — Header: graph name + Revit project
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Graph name (prominent, top) -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Graph"
                               Foreground="{StaticResource FgMuted}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="TbGraphName"
                               Text="(no graph open)"
                               Foreground="{StaticResource FgAccent}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Revit project (secondary, below graph) -->
                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Revit project"
                               Foreground="{StaticResource FgMuted}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock x:Name="TbRevitProject"
                               Text="(no Revit project)"
                               Foreground="#FFEBEBEB"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Logo / badge top-right -->
                <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                        Background="#22FFFFFF"
                        CornerRadius="4"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0">
                    <TextBlock Text="CONTRABANDA"
                               Foreground="{StaticResource FgAccent}"
                               FontSize="10"
                               FontWeight="Bold"
                               LetterSpacing="2"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 1 — Top separator
        ═══════════════════════════════════════════════════════ -->
        <Rectangle Grid.Row="1" Fill="{StaticResource Separator}"/>

        <!-- ═══════════════════════════════════════════════════════
             ROW 2 — Chat output (scrollable)
        ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2"
                      x:Name="ChatScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="12,8"
                      Background="#FF2D2D30">
            <StackPanel x:Name="ChatMessages" Margin="0,4"/>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════
             ROW 3 — Input row
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource BgPanel}"
                Padding="12,10">
            <DockPanel LastChildFill="True">
                <Button x:Name="BtnSend"
                        DockPanel.Dock="Right"
                        Style="{StaticResource SendButton}"
                        Height="38"
                        Margin="8,0,0,0"
                        Click="BtnSend_Click"
                        Content="Send"/>
                <TextBox x:Name="TbInput"
                         Style="{StaticResource ChatInput}"
                         Height="38"
                         KeyDown="TbInput_KeyDown"
                         ToolTip="Type a message and press Enter or Send"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 4 — Bottom separator
        ═══════════════════════════════════════════════════════ -->
        <Rectangle Grid.Row="4" Fill="{StaticResource Separator}"/>

        <!-- ═══════════════════════════════════════════════════════
             ROW 5 — Footer: selected node IDs
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="5"
                Background="{StaticResource BgPanel}"
                Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Selected nodes:"
                           Foreground="{StaticResource FgMuted}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock x:Name="TbSelectedNodes"
                           Text="(none)"
                           Foreground="#FFEBEBEB"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontFamily="Consolas, Courier New"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
